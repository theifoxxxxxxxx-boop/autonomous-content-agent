APP_ENV=dev
LOG_LEVEL=INFO
MOCK_MODE=false

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload
UPLOAD_DIR=./uploads
DEFAULT_MAX_RETRIES=3

# Vision provider: claude | gpt4o
VISION_PROVIDER=claude
OPENAI_API_KEY=
OPENAI_BASE_URL=
GPT4O_MODEL=gpt-4o

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# DeepSeek for Node B / Node C
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Network proxy
HTTP_PROXY=http://127.0.0.1:10808
HTTPS_PROXY=http://127.0.0.1:10808
ALL_PROXY=http://127.0.0.1:10808

# Browser
# mock | real | cloud
BROWSER_MODE=real
BROWSER_USE_ENABLED=true
BROWSER_HEADLESS=false
BROWSER_KEEP_ALIVE=true
BROWSER_OPERATION_TIMEOUT_SEC=240

# Real Browser mode (reuse local Chrome login)
BROWSER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
BROWSER_USER_DATA_DIR=C:/Users/<YOUR_USER>/AppData/Local/Google/Chrome/User Data
BROWSER_PROFILE_DIRECTORY=Default

# Cloud mode (optional)
BROWSER_CLOUD_PROJECT_ID=
BROWSER_CLOUD_LIVE_URL=
